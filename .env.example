# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role Key (server-side only, never expose to client)
# Used by webhook handler to bypass RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Backend API URL (webhook server)
# In development: http://localhost:3000
# In production: your deployed backend URL
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000

# ==================== Meta Platform Configuration ====================
# Get these from: https://developers.facebook.com/apps/YOUR_APP_ID/settings/

# Meta App credentials (from https://developers.facebook.com/apps/YOUR_APP_ID/settings/)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# The public URL of your app (used for OAuth redirect)
# Development: http://localhost:3001  |  Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Webhook verification token (you choose this, must match Meta App Dashboard config)
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token_here

# WhatsApp Business
# Get from: Meta Business Suite > WhatsApp > API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# Instagram
# Get from: Meta App Dashboard > Instagram > Basic Display
INSTAGRAM_APP_ID=your_ig_app_id

# Facebook Messenger
# Page Access Token from: Meta App Dashboard > Messenger > Settings
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token
MESSENGER_PAGE_ID=your_page_id

# ==================== Stripe Subscription Billing ====================
# Get keys from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_...) for development, live keys (sk_live_...) for production.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard (Products > Prices)
# Server-side only (used in webhook & checkout route for plan mapping)
STRIPE_PRICE_TROPIC_MONTHLY=price_...
STRIPE_PRICE_TROPIC_ANNUAL=price_...
STRIPE_PRICE_ISLAND_PRO_MONTHLY=price_...
STRIPE_PRICE_ISLAND_PRO_ANNUAL=price_...

# Client-side publishable key (needed if using Stripe.js / Elements directly)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Client-side price IDs (exposed to browser for pricing cards upgrade buttons)
NEXT_PUBLIC_STRIPE_PRICE_TROPIC_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_TROPIC_ANNUAL=price_...
NEXT_PUBLIC_STRIPE_PRICE_ISLAND_PRO_MONTHLY=price_...
NEXT_PUBLIC_STRIPE_PRICE_ISLAND_PRO_ANNUAL=price_...
